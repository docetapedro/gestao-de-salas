# ===========================================================================
# Banco de dados — Neon (Postgres serverless)
# Crie em https://neon.tech, copie a "Connection string" (Pooled) e cole aqui.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ===========================================================================
# Segredo do JWT de sessão. Gere um valor aleatório longo, por exemplo:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ---------------------------------------------------------------------------
AUTH_SECRET="troque-por-um-segredo-bem-longo-e-aleatorio"

# ===========================================================================
# Resend — envio de emails (https://resend.com)
# ---------------------------------------------------------------------------
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
# Remetente verificado no Resend. Em testes pode usar onboarding@resend.dev
EMAIL_FROM="Gestão de Salas <onboarding@resend.dev>"

# ===========================================================================
# Avisos de evento
# Janela (em minutos) antes do início do evento para disparar o aviso.
# ---------------------------------------------------------------------------
NOTIFY_WINDOW_MINUTES="30"

# Segredo usado para proteger a rota de cron (/api/cron/notify).
# O Vercel Cron envia automaticamente o header Authorization com este valor.
CRON_SECRET="troque-por-outro-segredo-aleatorio"
