// Schema de DESENVOLVIMENTO LOCAL (SQLite).
// Os modelos são idênticos ao schema.prisma de produção (Postgres);
// só muda o provider. Use com:
//   npx prisma generate --schema prisma/schema.dev.prisma
//   npx prisma db push  --schema prisma/schema.dev.prisma
// (DATABASE_URL deve ser algo como "file:./dev.db")

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  // Nome de utilizador opcional — permite login por email OU username.
  username  String?  @unique
  password  String
  role      String   @default("VIEWER")
  // Perfil de permissões (opcional). ADMIN (role) continua super-admin.
  perfilId  String?
  perfil    Perfil?  @relation(fields: [perfilId], references: [id], onDelete: SetNull)
  notify    Boolean  @default(true)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events Event[] @relation("EventCreator")

  @@index([perfilId])
}

// Perfil de acesso: conjunto de permissões por módulo.
// `permissoes` é um JSON (texto) { modulo: "view" | "manage" }; ausência = sem acesso.
model Perfil {
  id         String   @id @default(cuid())
  nome       String   @unique
  descricao  String?
  permissoes String   @default("{}")
  sistema    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users User[]
}

model Room {
  id        String   @id @default(cuid())
  name      String   @unique
  location  String?
  capacity  Int?
  color     String   @default("#1d4ed8")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events   Event[]
  projects Project[]
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  roomId      String
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?     @relation("EventCreator", fields: [createdById], references: [id], onDelete: SetNull)
  notifiedAt  DateTime?
  seriesId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([roomId, startAt])
  @@index([startAt])
  @@index([seriesId])
}

// ===========================================================================
// Módulo: Gestão de Projectos (Formações)
// Objectivo final: produzir o "Relatório de Formação — One Page Report",
// com indicadores de público, financeiro/ROI e qualidade por projecto.
// ===========================================================================

// Pilar estratégico / área a que o projecto pertence.
model Pilar {
  id        String    @id @default(cuid())
  nome      String    @unique
  createdAt DateTime  @default(now())
  projects  Project[]
}

// Formador / corpo técnico. Pode ser interno ou externo.
model Formador {
  id        String            @id @default(cuid())
  nome      String
  tipo      String            @default("INTERNO") // INTERNO | EXTERNO
  telefone  String?
  email     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  projetos  ProjectFormador[]
}

// Tipo de rubrica financeira (receita ou custo), ex.: "Valor do IVA 14%".
model RubricaTipo {
  id        String           @id @default(cuid())
  nome      String
  tipo      String           @default("CUSTO") // RECEITA | CUSTO
  ordem     Int              @default(0)
  createdAt DateTime         @default(now())
  itens     FinanceiroItem[]

  @@unique([nome, tipo])
}

// Projecto / Formação — entidade central do relatório.
model Project {
  id           String    @id @default(cuid())
  codigo       String?   @unique // Código sequencial automático (ex.: PACT.0001)
  nome         String
  descricao    String?
  // Segmento de mercado (B2C, B2B, B2G). Coluna mantém o nome antigo para evitar migração destrutiva.
  segmentoMercado String? @map("areaTematica")
  codigoTurma     String?

  pilarId String?
  pilar   Pilar?  @relation(fields: [pilarId], references: [id], onDelete: SetNull)
  // "Local / Sala" reutiliza a tabela de Salas (Room) já existente.
  localId String?
  local   Room?   @relation(fields: [localId], references: [id], onDelete: SetNull)
  // Cliente da formação (tabela própria).
  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  dataInicio      DateTime?
  dataFim         DateTime?
  duracaoHoras    Float?
  modalidade      String? // Presencial | Online | Híbrido
  nivel           String? // BASICO | INTERMEDIO | AVANCADO
  formadorInterno Boolean @default(true)
  selecaoFormador String?

  // Indicadores de qualidade (entrada manual) — "Real / Status" no relatório.
  nps           Float?
  taxaConclusao Float? // 0-100 (%)
  taxaPresenca  Float? // 0-100 (%)
  taxaAprovacao Float? // 0-100 (%)
  avalFormador  Float? // escala (ex.: 4.3)
  reclamacoes   Int    @default(0)

  // Avaliação por critério (NPS detalhado) — 0-100 ou escala.
  avConteudo       Float?
  avClareza        Float?
  avMateriais      Float?
  avOrganizacao    Float?
  avAplicabilidade Float?

  comentarios           String?
  responsavelPedagogica String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  formadores    ProjectFormador[]
  participantes Participante[]
  financeiro    FinanceiroItem[]
  turmas        Turma[]

  @@index([pilarId])
  @@index([localId])
  @@index([clienteId])
}

// Turma / edição de um projecto (formação). Um projecto pode ter várias turmas;
// os lançamentos financeiros são feitos por turma.
model Turma {
  id         String    @id @default(cuid())
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  codigo     String? // Identificação da turma (ex.: "T1", "2026-01")
  nome       String?
  dataInicio DateTime?
  dataFim    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  financeiro FinanceiroItem[]

  @@index([projectId])
}

// Cliente / conta a quem a formação é prestada (ex.: "AUREA — B2C Particulares").
model Cliente {
  id        String    @id @default(cuid())
  nome      String    @unique
  tipo      String    @default("B2C") // B2B | B2C
  telefone  String?
  email     String?
  descricao String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]
  // Movimentos de stock (saídas) em que este cliente é o destino.
  movimentosStock MovimentoStock[]
}

// Ligação N:N entre projecto e formadores (múltiplos formadores por projecto).
model ProjectFormador {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  formadorId String
  formador   Formador @relation(fields: [formadorId], references: [id], onDelete: Cascade)
  papel      String?

  @@unique([projectId, formadorId])
  @@index([projectId])
}

// Participante / formando inscrito num projecto.
model Participante {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tipo       String  @default("B2C") // B2B | B2C
  nome       String? // opcional: rótulo/contacto do grupo
  origem     String? // Empresa / Departamento (agrupador de "Participantes por Origem")
  quantidade Int     @default(1) // nº de formandos representados por esta linha (grupo)
  descricao String?
  telefone  String?
  email     String?
  concluidos Int     @default(0) // nº de formandos do grupo que concluíram (0..quantidade)
  // DEPRECADO: substituído por `concluidos`. Mantido só para o deploy não
  // apagar a coluna em produção (evita perda de dados no `db push`). Não usar.
  concluido Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([projectId])
}

// Lançamento financeiro por rubrica: previsto vs realizado.
model FinanceiroItem {
  id        String      @id @default(cuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // Turma a que o lançamento pertence (novos lançamentos são por turma).
  turmaId   String?
  turma     Turma?      @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  rubricaId String
  rubrica   RubricaTipo @relation(fields: [rubricaId], references: [id], onDelete: Cascade)
  previsto  Float       @default(0)
  realizado Float       @default(0)

  // Um registo por rubrica dentro da mesma turma.
  @@unique([turmaId, rubricaId])
  @@index([projectId])
  @@index([turmaId])
}

// ===========================================================================
// Módulo: Controlo de Stock (entradas/saídas, produtos, fornecedores)
// Baseado em Gestao_Stock.xlsx: Produto, Empresa (fornecedor/cliente),
// Data, Movimento (Entrada/Saída), Quantidade, Remanescente (calculado).
// ===========================================================================

// Produto/artigo controlado em stock (ex.: "Canetas", "Agendas").
// O stock actual é calculado a partir dos movimentos (Σentradas − Σsaídas).
model Produto {
  id          String   @id @default(cuid())
  nome        String   @unique
  unidade     String   @default("un") // unidade de medida (un, cx, kg, ...)
  stockMinimo Int? // alerta de stock baixo (opcional)
  descricao   String?
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  movimentos MovimentoStock[]
}

// Fornecedor — origem das entradas de stock (ex.: "TIS - MARKETING").
model Fornecedor {
  id        String   @id @default(cuid())
  nome      String   @unique
  telefone  String?
  email     String?
  descricao String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movimentos MovimentoStock[]
}

// Movimento de stock: entrada (de um fornecedor) ou saída (para um cliente).
model MovimentoStock {
  id         String   @id @default(cuid())
  produtoId  String
  produto    Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  tipo       String // ENTRADA | SAIDA
  quantidade Int
  data       DateTime @default(now())

  // Entrada → fornecedor; Saída → cliente (reutiliza a tabela Cliente dos Projectos).
  fornecedorId String?
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  clienteId    String?
  cliente      Cliente?    @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  observacao  String?
  createdById String?
  createdAt   DateTime @default(now())

  @@index([produtoId, data])
  @@index([tipo])
}

// ===========================================================================
// Módulo: Gamificação (Team Building)
// Um evento de team building agrupa equipas que competem em dinâmicas.
// A pontuação é lançada por equipa em cada dinâmica; o ranking geral do
// evento é a soma dos pontos (multiplicados pelo peso da dinâmica).
// ===========================================================================

// Evento / sessão de team building (ex.: "Kick-off 2026").
model TeamBuildingEvento {
  id          String   @id @default(cuid())
  nome        String
  descricao   String?
  local       String?
  data        DateTime?
  ativo       Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  equipas   Equipa[]
  dinamicas Dinamica[]
}

// Equipa participante de um evento. A pontuação é sempre por equipa.
model Equipa {
  id        String             @id @default(cuid())
  eventoId  String
  evento    TeamBuildingEvento @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  nome      String
  cor       String             @default("#2563eb") // cor da equipa (ranking/projeção)
  lema      String? // slogan opcional
  ordem     Int                @default(0)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  membros        EquipaMembro[]
  classificacoes Classificacao[]
  submissoes     QuizSubmissao[]

  @@index([eventoId])
}

// Membro (nome) de uma equipa — opcional.
model EquipaMembro {
  id       String @id @default(cuid())
  equipaId String
  equipa   Equipa @relation(fields: [equipaId], references: [id], onDelete: Cascade)
  nome     String

  @@index([equipaId])
}

// Dinâmica / desafio dentro de um evento (ex.: "Caça ao tesouro").
model Dinamica {
  id        String             @id @default(cuid())
  eventoId  String
  evento    TeamBuildingEvento @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  nome      String
  descricao String?
  ordem     Int                @default(0)
  // Multiplicador dos pontos desta dinâmica no ranking geral (default 1).
  peso      Float              @default(1)
  // Tipo de dinâmica: "manual" (pontuação lançada à mão) ou "quiz" (questionário por QR Code).
  tipo            String  @default("manual")
  // ---- Configuração específica do quiz ----
  quizAberto      Boolean @default(false) // aceita respostas neste momento
  valorPorAcerto  Float   @default(10) // pontos por pergunta certa
  bonusRapidezMax Float   @default(20) // bónus máximo de rapidez por membro (0 = sem bónus)
  tempoLimiteSeg  Int? // limite de tempo (s) para o bónus de rapidez; null = sem bónus de tempo
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  classificacoes Classificacao[]
  perguntas      QuizPergunta[]
  submissoes     QuizSubmissao[]

  @@index([eventoId])
}

// Pontuação de uma equipa numa dinâmica (um registo por equipa/dinâmica).
model Classificacao {
  id         String   @id @default(cuid())
  dinamicaId String
  dinamica   Dinamica @relation(fields: [dinamicaId], references: [id], onDelete: Cascade)
  equipaId   String
  equipa     Equipa   @relation(fields: [equipaId], references: [id], onDelete: Cascade)
  pontos     Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([dinamicaId, equipaId])
  @@index([dinamicaId])
  @@index([equipaId])
}

// Pergunta de um quiz (dinâmica tipo "quiz").
model QuizPergunta {
  id         String   @id @default(cuid())
  dinamicaId String
  dinamica   Dinamica @relation(fields: [dinamicaId], references: [id], onDelete: Cascade)
  enunciado  String
  ordem      Int      @default(0)

  opcoes QuizOpcao[]

  @@index([dinamicaId])
}

// Opção de resposta de uma pergunta; `correta` define o gabarito.
model QuizOpcao {
  id         String       @id @default(cuid())
  perguntaId String
  pergunta   QuizPergunta @relation(fields: [perguntaId], references: [id], onDelete: Cascade)
  texto      String
  correta    Boolean      @default(false)
  ordem      Int          @default(0)

  @@index([perguntaId])
}

// Submissão de um membro a um quiz. Os pontos da equipa na dinâmica são a soma
// dos pontos das submissões dos seus membros (recalculado a cada submissão).
model QuizSubmissao {
  id             String   @id @default(cuid())
  dinamicaId     String
  dinamica       Dinamica @relation(fields: [dinamicaId], references: [id], onDelete: Cascade)
  equipaId       String
  equipa         Equipa   @relation(fields: [equipaId], references: [id], onDelete: Cascade)
  nomeMembro     String
  tempoMs        Int // tempo total de resposta (ms)
  certas         Int
  totalPerguntas Int
  pontos         Float    @default(0)
  createdAt      DateTime @default(now())

  @@unique([dinamicaId, equipaId, nomeMembro])
  @@index([dinamicaId])
  @@index([equipaId])
}
